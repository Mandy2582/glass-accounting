# Arjun Glass Accounting Env Configurations
# Copy this file to .env.local to customize your settings in development.

# --- Direct SMTP Email Settings ---
# Option A: Generic SMTP (Titan Email, Zoho, or any custom domain mailbox).
# If EMAIL_HOST is set, these take priority over the Gmail settings below.
# Titan Email (bundled with BigRock/GoDaddy hosting) settings:
#   EMAIL_HOST=smtp.titan.email
#   EMAIL_PORT=465
#   EMAIL_SECURE=true
#   EMAIL_USER=you@arjunglasshouse.com
#   EMAIL_PASSWORD=your-mailbox-password
#   EMAIL_FROM=you@arjunglasshouse.com
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Option B: Gmail fallback (used only if EMAIL_HOST above is empty).
# Registered Gmail/Google Account address to send estimates and POs from
GMAIL_USER=your-email@gmail.com

# 16-character Google App Password (not your standard account password)
# Generate one at: Google Account -> Security -> 2-Step Verification -> App Passwords
GMAIL_APP_PASSWORD=your-gmail-app-password

# --- Company Metadata for Invoice and PDF Headers ---
COMPANY_NAME=Arjun Glass House
COMPANY_ADDRESS=Your Business Address Here
COMPANY_PHONE=+91 12345 67890
COMPANY_EMAIL=your-company-email@gmail.com

# Public WhatsApp number used by customer-facing quote buttons.
# Use country code without spaces if possible, e.g. +919876543210.
NEXT_PUBLIC_COMPANY_WHATSAPP=+91 12345 67890

# --- App Roles ---
# Comma-separated login emails that should receive full admin access.
# Users not listed here, and without Supabase user metadata role=admin, receive normal limited access.
NEXT_PUBLIC_ADMIN_EMAILS=owner@example.com,manager@example.com

# --- Supabase ---
# Add these in Vercel Project Settings -> Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

# --- Customer Sessions ---
# Random 32+ character secret used to sign customer login cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CUSTOMER_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- OpenAI ---
# Used by scripts/generate_sora_video.mjs.
# Also used by WhatsApp image/drawing intake when customers send photos or sketches.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_VISION_MODEL=gpt-4.1-mini

# --- WhatsApp Business Cloud API ---
# Inbound only: incoming text/images are parsed into draft orders. Nothing is
# ever sent back to the customer.
# Webhook callback URL: https://your-domain.com/api/whatsapp/webhook
# Use a long random string here and paste the same value into Meta's webhook verify token field.
WHATSAPP_VERIFY_TOKEN=change-this-long-random-token

# Optional but recommended. Used to validate x-hub-signature-256 on incoming webhook POSTs.
WHATSAPP_APP_SECRET=your-meta-app-secret

# Optional. Only needed to download image attachments for vision analysis.
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_GRAPH_API_VERSION=v23.0

# --- Email order intake (scripts/email-intake-daemon.mjs) ---
# Watches the EMAIL_USER mailbox above via IMAP IDLE and parses incoming
# text/photo emails into draft orders, the same as WhatsApp but inbound-only.
# Shared secret between the daemon and /api/email-intake/webhook -- generate
# with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_INTAKE_SECRET=change-this-long-random-secret
# Defaults to imap.titan.email:993; override if using a different provider.
EMAIL_IMAP_HOST=imap.titan.email
EMAIL_IMAP_PORT=993

# --- GST e-Way Bill (NIC Direct API, no GSP) ---
# Requires "Direct API" access to be registered on the e-Way Bill portal
# (ewaybillgst.gov.in -> Registration -> For GSP), separate from the normal
# portal login used to generate bills by hand -- this issues a dedicated API
# username/password and a client_id/app key. Direct API also requires
# whitelisting this server's public IP with NIC during that registration.
# EWB_BASE_URL/paths must be verified against the integration document NIC
# provides at registration (src/lib/ewayBill.ts has the exact spots to
# check/adjust if their field names differ from what's implemented here).
EWB_BASE_URL=
EWB_GSTIN=
EWB_USERNAME=
EWB_PASSWORD=
EWB_CLIENT_ID=
