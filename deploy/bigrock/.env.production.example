NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase
# Use hosted Supabase for first deployment unless we intentionally self-host Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Company
NEXT_PUBLIC_COMPANY_WHATSAPP=
NEXT_PUBLIC_ADMIN_EMAILS=
COMPANY_NAME=Arjun Glass House
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=

# Email, optional
# Preferred: generic SMTP (e.g. Titan Email that comes with BigRock/GoDaddy hosting)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Fallback: Gmail (used only if EMAIL_HOST above is empty)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# WhatsApp Cloud API, optional (inbound-only, no replies sent)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=

# Email order intake daemon (scripts/email-intake-daemon.mjs), optional
EMAIL_INTAKE_SECRET=
EMAIL_IMAP_HOST=imap.titan.email
EMAIL_IMAP_PORT=993

