# App
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://arjunglasshouse.com

# Supabase API.
# For hosted Supabase, use your hosted Supabase project URL and anon key.
# For self-hosted Supabase, this should point to your API gateway domain,
# for example https://api.arjunglasshouse.com.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Company / WhatsApp
NEXT_PUBLIC_COMPANY_WHATSAPP=
NEXT_PUBLIC_ADMIN_EMAILS=
COMPANY_NAME=Arjun Glass House
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=

# Mail, optional
# Preferred: generic SMTP (e.g. Titan Email that comes with BigRock/GoDaddy hosting)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Fallback: Gmail (used only if EMAIL_HOST above is empty)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# WhatsApp Cloud API, optional
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

